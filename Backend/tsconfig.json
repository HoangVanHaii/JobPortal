{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist",
    "rootDir": "."
  },
  "ts-node": {
    "files": true
  },
  "include": [
    "src", 
    "server.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}